# blog.me — environment variables (copy to .env.local and fill in)
# All are client-exposed (NEXT_PUBLIC_) by design for this static site.

# EmailJS (contact form) — https://www.emailjs.com/
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_CONTACT_TO_EMAIL=you@example.com
NEXT_PUBLIC_CONTACT_TO_NAME=Your Name

# Competitive Programming handles (LeetCode / Codeforces)
NEXT_PUBLIC_LEETCODE_USERNAME=jooncco
NEXT_PUBLIC_CODEFORCES_USERNAME=jooncco
